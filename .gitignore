build/

# XSim journal and checkpoint files that land in repo root
*.jou
*.pb
*.wdb
*.log

# Waveform config — auto-generated by make GUI=1
wave.wcfg

# XSim working directory if it ever appears in root
xsim.dir/

# Vivado project leftovers
.Xil/